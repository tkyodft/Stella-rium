---
import { SITE_TITLE, NAV_LINKS } from "../consts";
import HeaderLink from "./HeaderLink.astro";
---

<header class="topnav">
    <div class="nav-bar">
        <a href="/" class="brand">
            {SITE_TITLE}
            <span class="star" aria-hidden="true">☆</span>
        </a>

        <button class="hamburger" aria-label="Toggle navigation" aria-expanded="false">
            <span></span>
            <span></span>
            <span></span>
        </button>
    </div>
    <nav class="drawer" aria-hidden="true">
        <ul role="list">
            {
                NAV_LINKS.map(({ href, label }) => (
                    <li>
                        <HeaderLink href={href}>{label}</HeaderLink>
                    </li>
                ))
            }
        </ul>
    </nav>
</header>

<style lang="scss">
    @use "../styles/mixins" as *;

    .topnav {
        background: var(--charcoal);
        position: sticky;
        top: 0;
        z-index: 10;
        width: 100%;
        text-transform: uppercase;
    }

    .nav-bar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 1rem;
        height: 48px;
    }

    .brand {
        font-weight: 600;
        letter-spacing: 0.06em;
        text-transform: uppercase;
        color: var(--white);
        text-decoration: none;
        border-bottom: none;
        display: flex;
        align-items: center;
        gap: 0.375rem;
        transition: color 0.15s;

        &:hover {
            color: var(--plum-pale);
        }
    }

    .star {
        opacity: 0.7;
    }

    .hamburger {
        display: flex;
        flex-direction: column;
        justify-content: center;
        gap: 0.375rem;
        background: none;
        border: none;
        cursor: pointer;

        span {
            display: block;
            height: 1.5px;
            background: rgba(255, 255, 255, 0.8);
            transition: width 0.15s;

            &:nth-child(1) {
                width: 20px;
            }
            &:nth-child(2) {
                width: 20px;
            }
            &:nth-child(3) {
                width: 13px;
            }
        }

        &:hover span {
            background: var(--white);
        }
    }

    .drawer {
        background: var(--charcoal-2);
        border-top: 1px solid rgba(255, 255, 255, 0.06);
        display: none;

        &.open {
            display: block;
        }

        ul {
            list-style: none;
            margin: 0;
            padding: 0;
        }

        /* Style the HeaderLink <a> tags inside the drawer */
        :global(a) {
            display: flex;
            align-items: center;
            padding: 12px 18px;
            @include type-scale("sm");
            font-weight: 400;
            letter-spacing: 0.06em;
            color: rgba(255, 255, 255, 0.65);
            text-decoration: none;
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
            position: relative;
            transition:
                background 0.12s,
                color 0.12s;

            &:before {
                content: "";
                position: absolute;
                z-index: -1;
                inset: 0;
                background: var(--plum);
                transform: scaleY(0);
                transform-origin: 50% 0;
                transition-property: transform;
                transition-duration: 0.2s;
                transition-timing-function: ease-in-out;
            }

            &:hover,
            &.active {
                background: var(--plum);
                color: var(--white);

                @include md {
                    background: transparent;
                }

                &::before {
                    transform: scaleY(1);
                }
            }
        }
    }

    @include md {
        .topnav {
            display: flex;
            align-items: stretch;
        }

        .nav-bar {
            padding: 0;
            height: 48px;
            justify-content: flex-start;
            flex-shrink: 0;
        }

        .brand {
            padding: 0 1.375rem;
            height: 48px;
            border-right: 1px solid rgba(255, 255, 255, 0.08);
            flex-shrink: 0;

            &:hover {
                color: var(--white);
                background: var(--plum);
            }
        }

        .hamburger {
            display: none;
        }

        .drawer {
            display: flex !important;
            align-items: stretch;
            flex: 1;
            background: transparent;
            border-top: none;

            ul {
                display: flex;
                align-items: stretch;
                flex: 1;
            }

            :global(a) {
                height: 48px;
                padding: 0 1rem;
                border-bottom: none;
                @inlcude type-scale("sm");
            }
        }

        .affil-link {
            border-top: none;
            border-left: 1px solid rgba(255, 255, 255, 0.08);
            height: 48px;
            padding: 0 18px;
        }
    }
</style>
<script>
    const hamburger = document.querySelector<HTMLButtonElement>(".hamburger");
    const drawer = document.querySelector<HTMLElement>(".drawer");

    if (!hamburger || !drawer) {
        throw new Error("Nav elements not found — check your HTML structure.");
    }

    function openDrawer() {
        drawer!.classList.add("open");
        hamburger!.setAttribute("aria-expanded", "true");
        drawer!.removeAttribute("aria-hidden");
        // Move focus into the drawer so keyboard users land on the first link
        drawer!.querySelector<HTMLAnchorElement>("a")?.focus();
    }

    function closeDrawer() {
        drawer!.classList.remove("open");
        hamburger!.setAttribute("aria-expanded", "false");
        drawer!.setAttribute("aria-hidden", "true");
        // Return focus to the button that opened it
        hamburger!.focus();
    }

    function isOpen() {
        return drawer!.classList.contains("open");
    }

    // Toggle on hamburger click
    hamburger.addEventListener("click", () => {
        isOpen() ? closeDrawer() : openDrawer();
    });

    // Close on Escape key
    document.addEventListener("keydown", (e) => {
        if (e.key === "Escape" && isOpen()) {
            closeDrawer();
        }
    });

    // Close when clicking outside the nav
    document.addEventListener("click", (e) => {
        const nav = document.querySelector<HTMLElement>(".topnav");
        if (nav && !nav.contains(e.target as Node) && isOpen()) {
            closeDrawer();
        }
    });
</script>
