---
import { CREDITS, SITE_TITLE, SITE_EST } from "../consts";
import FooterSection from "./FooterSection.astro";
const today = new Date();
---

<footer class="site-footer">
    <div class="footer-inner">
        <FooterSection heading="Lorem ipsum">
            <p class="footer-text">
                Lorem ipsum dolor sit amet, consectetur adipiscing elit. Phasellus scelerisque eros sollicitudin,
                dignissim ipsum at, elementum velit. Cras efficitur sed dolor non facilisis. Fusce non eros aliquam,
                vulputate leo tincidunt, semper elit. Cras vel vulputate ligula.
            </p>
        </FooterSection>

        <FooterSection heading="Credits">
            <ul class="credit-links" role="list">
                {
                    CREDITS.map(({ label, href }) => (
                        <li>
                            <a href={href} target="_blank" rel="noopener noreferrer">
                                {label}
                            </a>
                        </li>
                    ))
                }
            </ul>
        </FooterSection>
    </div>

    <div class="footer-base">
        {SITE_TITLE} &copy; {SITE_EST}–{today.getFullYear()} YOU
    </div>
</footer>

<style lang="scss">
    @use "../styles/mixins" as *;

    .site-footer {
        background: var(--charcoal);
    }

    .footer-inner {
        display: grid;
        gap: 1.5rem;
        padding: 1.5rem 1.125rem 1.25rem;

        @include md {
            grid-template-columns: 1fr 1fr;
            gap: 2.5rem;
            padding: 2rem 3rem 1.75rem;
        }
    }

    .footer-text {
        @include type-scale("sm");
        color: rgba(255, 255, 255, 0.7);
        line-height: 1.8;
        font-weight: 300;
        margin-block: 0;
    }

    .credit-links {
        list-style: none;
        display: grid;
        grid-template-columns: 1fr;

        @include sm {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    .credit-links li + li {
        margin-block: 0 0.1875rem;
    }

    .credit-links li a {
        display: inline-flex;
        align-items: center;
        gap: 0.375rem;
        @include type-scale("sm");
        color: rgba(255, 255, 255, 0.7);
        border-bottom: none;
        font-weight: 300;
        transition:
            color 0.14s,
            padding-inline 0.14s;

        &::before {
            content: "\2606";
            color: var(--plum);
            @include type-scale("sm");
            line-height: 1;
        }

        &:hover {
            color: var(--plum-pale);
            padding-inline: 0.25rem 0;
        }
    }

    .footer-base {
        border-top: 1px solid rgba(255, 255, 255, 0.06);
        padding: 0.625re 1.125rem;
        color: rgba(255, 255, 255, 0.7);
        text-align: center;
        @include type-scale("sm");
        @include md {
            padding: 0.625rem 3rem;
        }
    }
</style>
