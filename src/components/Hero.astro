---
// src/components/Hero.astro

import { SITE_TITLE, SITE_DESCRIPTION } from "../consts";
---

<div class="hero">
    <div class="hero-overlay" aria-hidden="true"></div>
    <div class="hero-text">
        <h1 class="hero-title">{SITE_TITLE}</h1>
        <p class="hero-sub">{SITE_DESCRIPTION}</p>
    </div>
</div>

<style lang="scss">
    @use "../styles/mixins" as *;

    .hero {
        width: 100%;
        height: 200px;
        overflow: hidden;
        position: relative;
        background-image: url("../assets/header.webp");
        background-size: cover;
        background-position: center center;

        @include md {
            height: 300px;
        }

        @include lg {
            height: 500px;
        }
    }

    .hero img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center 20%;
        display: block;
    }

    .hero-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(to right, rgba(30, 20, 50, 0.45) 0%, transparent 55%);
    }

    .hero-text {
        position: absolute;
        bottom: 1.5rem;
        left: 1.5rem;
    }

    .hero-title {
        @include type-scale("2xl");
        font-weight: 300;
        color: var(--white);
        letter-spacing: 0.12em;
        text-transform: uppercase;
        line-height: 1;
        text-shadow: 0 2px 20px rgba(20, 10, 40, 0.6);
        /* override global heading styles */
    }

    .hero-sub {
        @include type-scale("sm");
        letter-spacing: 0.28em;
        text-transform: uppercase;
        color: var(--peri-pale);
        font-weight: 400;
    }
</style>
